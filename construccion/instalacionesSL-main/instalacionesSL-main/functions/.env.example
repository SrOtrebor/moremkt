# JWT Secret para autenticación
JWT_SECRET=tu-secreto-jwt-aca

# Email Configuration (Gmail SMTP)
EMAIL_USER=tu-email@gmail.com
EMAIL_PASS=tu-app-password-aca

# URL base de la aplicación
BASE_URL=http://localhost:5000
FUNCTIONS_URL=http://localhost:5001/instalacione-2a21b/us-central1

# Google Calendar API - Service Account (Fallback)
GOOGLE_SERVICE_ACCOUNT_EMAIL=tu-service-account@appspot.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\ntu-llave-privada-aca\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=tu-calendar-id@gmail.com

# Mercado Pago Credentials
MP_ACCESS_TOKEN=tu-mp-access-token
MP_PUBLIC_KEY=tu-mp-public-key

# Google OAuth 2.0 Credentials (Para Google Meet automático)
GOOGLE_OAUTH_CLIENT_ID=tu-client-id
GOOGLE_OAUTH_CLIENT_SECRET=tu-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5001/api/admin/calendar/callback
