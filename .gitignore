# ============================================================
# .gitignore — MoreMKT
# Archivos que NO deben subirse a GitHub por seguridad.
# ============================================================

# Variables de entorno con claves secretas
functions/.env
functions/.env.*
.env
.env.*

# Dependencias de Node.js (se reinstalan con npm install)
functions/node_modules/
node_modules/

# Archivos del sistema
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
npm-debug.log*

# Firebase
.firebase/
